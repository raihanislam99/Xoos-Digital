RewriteEngine On

# ── Protect sensitive files ──
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
<FilesMatch "\.(env|sql|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Gzip Compression ──
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    Header append Vary User-Agent
</IfModule>

# ── Security Headers ──
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Browser Caching ──
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"

    # CSS, JavaScript
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"

    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"

    # Default
    ExpiresDefault "access plus 2 days"
</IfModule>

# ── Custom error pages ──
ErrorDocument 404 /xoosdigital/404.php
ErrorDocument 500 /xoosdigital/500.php

# Redirect .php URLs to clean URLs (external)
RewriteCond %{THE_REQUEST} \s/(about|services|portfolio|blog|contact|policy)\.php[\s?] [NC]
RewriteRule ^(about|services|portfolio|blog|contact|policy)\.php$ $1 [R=301,L,QSA]

# Redirect post.php?slug=X to /post/X (external)
RewriteCond %{THE_REQUEST} \s/post\.php\?slug=([^\s&]+) [NC]
RewriteRule ^post\.php$ post/%1? [R=301,L]

# Front-end clean URLs (internal)
RewriteRule ^about$ about.php [L]
RewriteRule ^services$ services.php [L]
RewriteRule ^portfolio$ portfolio.php [L]
RewriteRule ^blog$ blog.php [L]
RewriteRule ^contact$ contact.php [L]
RewriteRule ^policy$ policy.php [L,QSA]

# Sitemap (internal)
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Blog posts (internal)
RewriteRule ^post/([^/]+)$ post.php?slug=$1 [L,QSA]


